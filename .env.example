# One Render Docker service: Tammy Discord live bridge + Second Life agent.

# Discord live feed and keyword concierge
DISCORD_TOKEN=
CLIENT_ID=
GUILD_ID=
# Required for Academy admin commands and scheduled student DMs.
ACADEMY_SHARED_SECRET=
# Discord user allowed to use /academy-assign, /academy-note, and review controls.
ACADEMY_OWNER_ID=1197552066269282306
TAMMY_LIVE_CHANNEL_ID=
TAMMY_LIVE_POLL_MS=5000
# Optional comma-separated allowlist. Empty means all guild text channels.
TAMMY_HELP_CHANNEL_IDS=

# Shared Neon database: use the exact same full URL as Lifeline Assistant.
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Second Life
SL_FIRST_NAME=lifelinerpassistant
SL_LAST_NAME=Resident
SL_PASSWORD=
SL_START_LOCATION=Ethereal Paradise/85/129/35
TAMMY_MODE=automated

# In-world intelligence
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Base URL only; Tammy appends /api/tammy/guest-context.
LIFELINE_API_URL=https://your-lifeline-backend.onrender.com
LIFELINE_API_SECRET=

# Render supplies PORT automatically.
PORT=3000
