# Tammy Brightwood Bot Environment Variables Template
# Copy this to .env and fill in your values

# ============================================
# DISCORD BOT CREDENTIALS (Required)
# ============================================
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_id_here
GUILD_ID=your_server_id_here

# ============================================
# GOOGLE SHEETS IDS (Required)
# Get these from the URL: https://docs.google.com/spreadsheets/d/[SHEET_ID]/edit
# ============================================
TAMMY_STUDENTS_SHEET_ID=
TAMMY_TEACHERS_SHEET_ID=
TAMMY_CLASSES_SHEET_ID=
TAMMY_ASSIGNMENTS_SHEET_ID=
TAMMY_SUBMISSIONS_SHEET_ID=
TAMMY_GRADE_LEDGER_SHEET_ID=
TAMMY_ATTENDANCE_SHEET_ID=
TAMMY_ANNOUNCEMENTS_SHEET_ID=
TAMMY_TEACHER_ACTIONS_SHEET_ID=
TAMMY_PARENT_LINKS_SHEET_ID=

# ============================================
# GOOGLE SERVICE ACCOUNT (Required for Sheets)
# 1. Create service account in Google Cloud Console
# 2. Download JSON credentials
# 3. Base64 encode the entire JSON and paste here
#
# To base64 encode:
# - Windows PowerShell: [Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes((Get-Content service-account.json -Raw)))
# - Mac/Linux: base64 < service-account.json | tr -d '\n'
# ============================================
GOOGLE_SERVICE_ACCOUNT_JSON=

# ============================================
# DISCORD ROLES (Required - Role IDs)
# How to get Role ID:
# 1. Enable Developer Mode in Discord
# 2. Right-click role in server settings
# 3. Click "Copy Role ID"
# ============================================
TAMMY_ADMIN_ROLE_ID=
TAMMY_TEACHER_ROLE_ID=
TAMMY_STAFF_ROLE_ID=
TAMMY_STUDENT_ROLE_ID=
TAMMY_PARENT_ROLE_ID=

# ============================================
# DISCORD CHANNELS (Required - Channel IDs)
# How to get Channel ID:
# 1. Enable Developer Mode in Discord
# 2. Right-click channel
# 3. Click "Copy Channel ID"
# ============================================
TAMMY_ANNOUNCE_CHANNEL_ID=
TAMMY_OPERATIONS_CHANNEL_ID=
TAMMY_WELCOME_CHANNEL_ID=
TAMMY_ALLOWED_CATEGORY_IDS=

# ============================================
# OPTIONAL: Portal URLs (for web portals)
# ============================================
ACADEMY_STUDENT_PORTAL_URL=https://your-portal.com/student
ACADEMY_PARENT_PORTAL_URL=https://your-portal.com/parent
ACADEMY_TEACHER_PORTAL_URL=https://your-portal.com/teacher
ACADEMY_ADMIN_PORTAL_URL=https://your-portal.com/admin

# ============================================
# OPTIONAL: Additional Channels
# ============================================
TAMMY_LOG_CHANNEL_ID=
TAMMY_ENROLLMENT_CHANNEL_ID=
TAMMY_EVENTS_CHANNEL_ID=
TAMMY_PARENT_NOTICES_CHANNEL_ID=
TAMMY_FACULTY_LOUNGE_CHANNEL_ID=
TAMMY_RECORDS_CHANNEL_ID=

# ============================================
# OPTIONAL: Timezone & Scheduler
# ============================================
TAMMY_TIMEZONE=America/Los_Angeles
TAMMY_DAILY_BULLETIN_HOUR=8
TAMMY_DAILY_PROMPT_HOUR=9
