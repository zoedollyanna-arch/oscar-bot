# =====================================================================================
#  Tammy Brightwood — Lifeline's automated Discord staff assistant
#  Copy to .env and fill in. Tammy SHARES the main Discord bot's Neon database.
# =====================================================================================

# ---- Discord ----
DISCORD_TOKEN=your_bot_token
CLIENT_ID=your_application_id
GUILD_ID=your_server_id

# ---- Shared database (SAME Neon DATABASE_URL as the main Discord bot / db.js) ----
# This is what makes Tammy and the Discord bot share data. Use the bot's Neon URL.
DATABASE_URL=postgres://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require

# ---- Roles (staff can action tickets / redeliveries / applications) ----
TAMMY_ADMIN_ROLE_ID=
TAMMY_STAFF_ROLE_IDS=            # comma-separated role IDs
TAMMY_TICKET_STAFF_ROLE_IDS=    # roles that can see ticket channels (defaults to admin+staff)

# ---- Channels ----
TAMMY_LOG_CHANNEL_ID=
TAMMY_WELCOME_CHANNEL_ID=       # greeting on member join (optional)
TAMMY_ANNOUNCE_CHANNEL_ID=      # default target for /announce
TAMMY_EVENTS_CHANNEL_ID=
TAMMY_OPERATIONS_CHANNEL_ID=    # where staff cards (redeliveries/escalations) are posted
TAMMY_APPLICATIONS_CHANNEL_ID=  # where /apply submissions are posted

# ---- Support tickets ----
TAMMY_TICKET_CATEGORY_ID=       # category to create private ticket channels under
TAMMY_TICKET_CHANNEL_PREFIX=support

# ---- FAQ auto-responder ----
TAMMY_FAQ_AUTOREPLY=true        # set false to disable message auto-answers
TAMMY_FAQ_CHANNEL_IDS=          # comma-separated channel IDs to watch (empty = all)

# ---- Render backend (Second Life HTTP integration) ----
LIFELINE_BACKEND_URL=https://your-backend.onrender.com
LIFELINE_BACKEND_SECRET=        # must match TAMMY_SECRET on the backend

# ---- Handy links surfaced in FAQ / commands ----
LIFELINE_LANDMARKS_URL=
LIFELINE_SUPPORT_URL=

# ---- Misc ----
TAMMY_TIMEZONE=America/Los_Angeles
PORT=3000

# ---- Second Life TammyAgent (runs in the same Docker service) ----
SL_FIRST_NAME=Tammy
SL_LAST_NAME=Resident
SL_PASSWORD=
SL_START_LOCATION=last
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
LIFELINE_API_URL=
LIFELINE_API_SECRET=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
TAMMY_MODE=automated
TAMMY_LIVE_CHANNEL_ID=
TAMMY_LIVE_POLL_MS=5000
